[sub_resource type="GDScript" id="GDScript_qoelj"]
script/source = "extends CharacterBody2D

var marker: Vector2
@onready var init_position: Vector2 = global_position

@onready var laser_sprite: AnimatedSprite2D = $GoobleMachinegunner/Machinegun/Laser
@onready var hurtbox: EnemyHurtboxComponent = $GoobleMachinegunner/EnemyHurtboxComponent
@onready var hitbox: EnemyHitboxComponent = $GoobleMachinegunner/Machinegun/Laser/EnemyHitboxComponent

@onready var lineup_timer: Timer = $LaserLineup
@onready var buildup_timer: Timer =  $LaserBuildup
@onready var finish_buildup_timer: Timer = $LaserFinishBuildup
@onready var firing_timer: Timer = $LaserFiring
@onready var sprite_anims: AnimationPlayer = $GoobleMachinegunner/SpriteAnims
@onready var manager: Node = $\"..\"
@onready var health: EnemyHealthComponent = $EnemyHealthComponent

func _ready() -> void:
	SignalBus.connect(\"reset\", _reset)

func _reset() -> void:
	global_position = marker

func start_routine(new_position: Marker2D) -> void:
	health.health = health.base_health
	sprite_anims.stop()
	sprite_anims.play(\"RESET\")
	$GoobleMachinegunner/Machinegun.track_location = true
	$GoobleMachinegunner/Machinegun/Static.play()
	sprite_anims.play(\"flying_loop\")
	marker = new_position.global_position
	hurtbox.set_deferred(\"monitorable\", true)
	lineup_timer.start()

func _physics_process(delta: float) -> void:
	global_position = lerp(global_position, marker, 2 * delta)
	
func _on_laser_lineup_timeout() -> void:
	buildup_timer.start()
	$GoobleMachinegunner/Machinegun/LaserBuildup.play()

func _on_laser_buildup_timeout() -> void:
	$GoobleMachinegunner/Machinegun/LaserRelease.play()
	finish_buildup_timer.start()

func _on_laser_finish_buildup_timeout() -> void:
	sprite_anims.play(\"firing_loop\")
	hitbox.set_deferred(\"monitoring\", true)
	laser_sprite.show()
	laser_sprite.play(\"init\")
	hurtbox.set_deferred(\"monitorable\", false)
	firing_timer.start()

func _on_laser_firing_timeout() -> void:
	marker = init_position
	laser_sprite.stop()
	laser_sprite.hide()
	hitbox.set_deferred(\"monitoring\", false)
	$GoobleMachinegunner/Machinegun.track_location = false
	manager.wave_gooble_finished_routine -= 1
	sprite_anims.play(\"flying_loop\")

func _on_enemy_health_component_died() -> void:
	print(\"And DOWN goes %s!\" % name)
	health.health = health.base_health
	hurtbox.set_deferred(\"monitorable\", false)
	$GoobleMachinegunner/Machinegun/Death.play()
	
	lineup_timer.stop()
	buildup_timer.stop()
	$GoobleMachinegunner/Machinegun/LaserBuildup.stop()
	$GoobleMachinegunner/Machinegun/LaserRelease.stop()
	
	manager.wave_gooble_alive_count -= 1
	manager.wave_gooble_finished_routine -= 1
	sprite_anims.play(\"death\")
	marker = init_position
"

