[sub_resource type="GDScript" id="GDScript_idnjq"]
script/source = "extends CharacterBody2D

var marker: Vector2
@onready var init_position: Vector2 = global_position

@onready var hurtbox: EnemyHurtboxComponent = $GoobleRPGGuy/EnemyHurtboxComponent

@onready var lineup_timer: Timer = $RPGLineup
@onready var cooldown_timer: Timer = $RPGCooldown
@onready var sprite_anims: AnimationPlayer = $GoobleRPGGuy/SpriteAnims
@onready var manager: Node = $\"..\"
@onready var health: EnemyHealthComponent = $EnemyHealthComponent

@onready var rocket_anims: AnimationPlayer = $GoobleRPGGuy/RPG/Rocket/Rocket/RocketAnim

var deflected: bool = false
var clip_size: int

func _ready() -> void:
	SignalBus.connect(\"reset\", _reset)

func _reset() -> void:
	global_position = marker

func start_routine(new_position: Marker2D) -> void:
	clip_size = randi_range(3, 5)
	health.health = health.base_health
	sprite_anims.stop()
	sprite_anims.play(\"RESET\")
	$GoobleRPGGuy/RPG.track_location = true
	sprite_anims.play(\"flying_loop\")
	marker = new_position.global_position
	hurtbox.set_deferred(\"monitorable\", true)
	lineup_timer.start()

func _physics_process(delta: float) -> void:
	global_position = lerp(global_position, marker, 2 * delta)
	
func cooldown_timer_wait_time() -> void:
	cooldown_timer.wait_time = randf_range(0.5, 2.5)

func _on_rpg_lineup_timeout() -> void:
	cooldown_timer_wait_time()
	cooldown_timer.start()

func _on_rpg_cooldown_timeout() -> void:
	cooldown_timer_wait_time()
	if clip_size:
		clip_size -= 1
		sprite_anims.play(\"firing\")
	else:
		stop_firing()

func stop_firing() -> void:
	marker = init_position
	$GoobleRPGGuy/RPG.track_location = false
	manager.wave_gooble_finished_routine -= 1
	sprite_anims.play(\"flying_loop\")

func _on_enemy_health_component_died(died_via_rpg: bool = false) -> void:
	print(\"And DOWN goes %s!\" % name)
	health.health = health.base_health
	hurtbox.set_deferred(\"monitorable\", false)
	$GoobleRPGGuy/RPG/Death.play()
	
	lineup_timer.stop()
	cooldown_timer.stop()
	
	manager.wave_gooble_alive_count -= 1
	manager.wave_gooble_finished_routine -= 1
	sprite_anims.play(\"death\")
	marker = init_position
	
	if !died_via_rpg && !manager.tell_player_to_deflect_check:
		await get_tree().create_timer(1).timeout
		manager.tell_player_to_deflect.emit()
		manager.tell_player_to_deflect_check = true


func _on_hittable_component_interacted() -> void:
	rocket_anims.play(\"deflect\")

func _on_rocket_anim_animation_finished(anim_name: StringName) -> void:
	match anim_name:
		\"fire\":
			rocket_anims.play(\"explosion\")
		\"deflect\":
			rocket_anims.play(\"RESET\")
			$Explosion/GameAnimationPlayer.play(\"explooode\")
			_on_enemy_health_component_died(true)
"

[sub_resource type="GDScript" id="GDScript_6jitc"]
script/source = "extends Sprite2D

@export var track_location: bool = false
@export var manager: Node

func _process(delta: float) -> void:
	if track_location:
		# thank you u/samsfacee
		rotation = lerp_angle(rotation, rotation + get_angle_to(manager.charlie.global_position), 4.5 * delta)
"

