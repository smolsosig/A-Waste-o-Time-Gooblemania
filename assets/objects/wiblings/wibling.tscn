[sub_resource type="GDScript" id="GDScript_iqinl"]
script/source = "extends AnimatedSprite2D

@onready var opportunity: Timer = $OpportunityTimer
@onready var blinker: Timer = $BlinkerTimer
var last_chance: bool = false

func _on_opportunity_timer_timeout() -> void:
	if !last_chance:
		opportunity.wait_time = 5
		opportunity.start()
		blinker.start()
		last_chance = true
	else:
		get_parent().remove_self()

func _on_blinker_timer_timeout() -> void:
	if modulate == Color.ORANGE_RED:
		modulate = Color.TRANSPARENT
	else:
		modulate = Color.ORANGE_RED
	blinker.start()
"

