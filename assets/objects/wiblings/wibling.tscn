[sub_resource type="GDScript" id="GDScript_lxwj6"]
script/source = "extends Area2D

func _on_area_entered(area: Area2D) -> void:
	if area is CharlieDetectableComponent:
		Staglobals.actual_wibl += get_parent().value
		
		var rng : RandomNumberGenerator = RandomNumberGenerator.new()
		SoundManager.play_sound(load(\"res://assets/objects/wiblings/sounds/collect%s.ogg\" % rng.randi_range(1, 7)))
		get_parent().remove_self()


func _on_timer_timeout() -> void:
	set_deferred(\"monitoring\", true)
"

