[sub_resource type="GDScript" id="GDScript_41pas"]
script/source = "extends Node

# proxy node for MusicManager
func play_music(music_file: String = \"spy_a.ogg\", player: int = 0, fade_in: float = 0) -> void:
	MusicManager.play_music(music_file, player, fade_in)

func stop_music(fade_out: float = 0, player: int = 0) -> void:
	MusicManager.stop_music(fade_out, player)
"

[sub_resource type="GDScript" id="GDScript_s1xa4"]
script/source = "extends Node

const rocket_patterns: Array = [1, 2, 3]
const rocket_patterns_2: Array = [1, 2, 3, 1, 2]
const attack_patterns: Array = [\"rocket\", \"minigun\", \"rocket\", \"sword\"]
const attack_patterns_2: Array = [\"rocket\", \"minigun\", \"rocket\", \"minigun\", \"sword\", \"sword2\", \"sword2\"]

signal done

var no_miniguns_please: int = 0
var minigun_count: int = 0:
	set(value):
		if value == 3:
			no_miniguns_please = 2
		minigun_count = value

@export var anim_player: AnimationPlayer
var attack_patterns_used: Array
var rocket_patterns_used: Array
var current_position: String = \"r\"

@onready var rockets: Array = [$\"../Rocket1/Rocket1/AnimPlayer\", $\"../Rocket2/Rocket2/AnimPlayer\", $\"../Rocket3/Rocket3/AnimPlayer\"]
@onready var rocket_containers: Array = [$\"../Rocket1\", $\"../Rocket2\", $\"../Rocket3\"]

var second_phase: bool = false
var defeated: bool = false

func _ready() -> void:
	SignalBus.connect(\"reset\", _reset)
	$\"../Twink/EnemyHurtboxComponent\".set_deferred(\"monitorable\", false)

func _reset() -> void:
	if !defeated && second_phase:
		second_phase = false
	elif defeated:
		get_parent().set_deferred(\"monitoring\", false)

func start_routine() -> void:
	$\"../Twink/EnemyHurtboxComponent\".damage_allowed = 0
	$\"../Twink/EnemyHurtboxComponent\".set_deferred(\"monitorable\", true)
	
	if !second_phase:
		attack_patterns_used = attack_patterns.duplicate()
	else:
		attack_patterns_used = attack_patterns_2.duplicate()
	attack_patterns_used.shuffle()
	
	_pick_next_action()

func new_attacks() -> void:
	attack_patterns_used = attack_patterns_2.duplicate()
	attack_patterns_used.shuffle()

func _pick_next_action() -> void:
	if !attack_patterns_used:
		start_routine()
	
	match attack_patterns_used[0]:
		\"rocket\":
			anim_player.play(\"rocket_prepare_%s\" % current_position)
		\"minigun\":
			if !no_miniguns_please:
				anim_player.play(\"minigun_%s\" % current_position)
				minigun_count += 1
			else:
				no_miniguns_please -= 1
				_pick_next_action()
		\"sword\":
			if current_position == \"l\": anim_player.play(\"sword_l2r\")
			else: anim_player.play(\"sword_r2l\")
		\"sword2\":
			if current_position == \"l\": anim_player.play(\"sword_l2r_2\")
			else: anim_player.play(\"sword_r2l_2\")
	
	attack_patterns_used.pop_front()

func _rocket_start() -> void:
	if !second_phase:
		rocket_patterns_used = rocket_patterns.duplicate()
	else:
		rocket_patterns_used = rocket_patterns_2.duplicate()
	rocket_patterns_used.shuffle()
	_rocket_fire_anim()

func _rocket_fire_anim() -> void:
	if !rocket_patterns_used:
		anim_player.play(\"rocket_end_%s\" % current_position)
		return
	
	anim_player.play(\"rocket_shoot%s_%s\" % [rocket_patterns_used[0], current_position])
	

func _rocket_fire() -> void:
	var temp_num: int = rocket_patterns_used[0] - 1
	rockets[temp_num].stop()
	rockets[temp_num].play(\"fire\")
	if current_position == \"r\": rocket_containers[temp_num].scale = Vector2(1, 1)
	else: rocket_containers[temp_num].scale = Vector2(-1, 1)
	rocket_patterns_used.pop_front()

func _on_game_animation_player_animation_finished(anim_name: StringName) -> void:
	# i am gonna get killed for this
	match anim_name:
		\"sword_r2l\":
			current_position = \"l\"
			start_routine()
		\"sword_l2r\":
			current_position = \"r\"
			start_routine()
		\"sword_r2l_2\":
			current_position = \"l\"
			start_routine()
		\"sword_l2r_2\":
			current_position = \"r\"
			start_routine()
		\"rocket_prepare_r\":
			_rocket_start()
		\"rocket_prepare_l\":
			_rocket_start()
		\"rocket_shoot1_l\":
			_rocket_fire_anim()
		\"rocket_shoot1_r\":
			_rocket_fire_anim()
		\"rocket_shoot2_l\":
			_rocket_fire_anim()
		\"rocket_shoot2_r\":
			_rocket_fire_anim()
		\"rocket_shoot3_l\":
			_rocket_fire_anim()
		\"rocket_shoot3_r\":
			_rocket_fire_anim()
		\"rocket_end_l\":
			_pick_next_action()
		\"rocket_end_r\":
			_pick_next_action()
		\"RESET\":
			anim_player.stop()
		\"death\":
			pass
		_:
			_pick_next_action()


func _on_enemy_health_component_health_changed(health: int, _decrease: bool) -> void:
	if health <= 500 && !second_phase:
		second_phase = true
		new_attacks()
		$\"../Phase2Alarm\".play()

func _on_enemy_health_component_died() -> void:
	get_parent().persistent = true
	get_parent().enable_on_start = false
	$\"../CharlieHealerComponent\".set_deferred(\"monitoring\", true)
	MusicManager.stop_music(0.5)
	anim_player.stop()
	anim_player.play(\"death\")
	await get_tree().create_timer(5).timeout
	MusicManager.play_music(\"spy_a.ogg\")
	emit_signal(\"done\")
"

