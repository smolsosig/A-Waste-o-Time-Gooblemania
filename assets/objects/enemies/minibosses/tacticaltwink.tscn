[sub_resource type="GDScript" id="GDScript_tp80q"]
script/source = "extends CharlieTrigger

@export var room_cam: CameraRegion2D
@export var boss_cam: CameraRegion2D

func ready() -> void:
	$CockBlocker.position = Vector2(2000, 0)

func _on_twink_logic_done() -> void:
	room_cam.global_position = Vector2(25700.0, 50.0)
	boss_cam.global_position = Vector2(26252.0, 1352.0)
	$CockBlocker.position = Vector2(2000, 0)
	SoundManager.play_sound(load(\"res://assets/objects/props/ph-door/door_open.ogg\"))

func _on_charlie_entered() -> void:
	$CockBlocker.position = Vector2(-1000, 0)
	SoundManager.play_sound(load(\"res://assets/objects/props/ph-door/door_close.ogg\"))
"

