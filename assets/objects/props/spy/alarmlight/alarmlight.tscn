[sub_resource type="GDScript" id="GDScript_20s1c"]
script/source = "extends Node2D

@export var is_on: bool = false:
	set(value):
		if value:
			get_node(\"AnimationPlayer\").play(\"on\")
		else:
			get_node(\"AnimationPlayer\").play(\"off\")
		
		is_on = value

func _ready() -> void:
	# not doing this causes the damn thing to break. lol
	set_light(is_on)

func set_light(on: bool) -> void:
	is_on = on
"

